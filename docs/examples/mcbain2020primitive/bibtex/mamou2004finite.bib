@article{mamou2004finite,
  abstract = {{This paper presents a comprehensive review of the numerical techniques used during the past half century and their accuracy in hydrodynamic stability analysis of plane parallel flows. The paper also describes a finite element solution of the Orr–Sommerfeld equation using high precision Hermite elements. A stability analysis technique is performed by imposing an infinitesimal perturbation to the laminar base flow to determine the thresholds of neutral instabilities or the growth rate of the perturbation for any Reynolds and wave numbers. Validation of the present numerical technique is performed for plane Poiseuille flow. The numerical results, obtained with uniform and nonuniform meshes, show excellent agreement with the most accurate results available in the literature.}},
  added-at = {2017-06-29T07:13:07.000+0200},
  author = {Mamou, M. and Khalid, M.},
  biburl = {https://www.bibsonomy.org/bibtex/2c49f4c62bd5a7056f8be59121d708309/gdmcbain},
  doi = {10.1002/fld.661},
  file = {mamou_04_finite_1081486.pdf},
  interhash = {557c880822aaf76c994a74b388f21634},
  intrahash = {c49f4c62bd5a7056f8be59121d708309},
  journal = {International Journal for Numerical Methods in Fluids},
  keywords = {usyd 76m10-finite-element-methods-in-fluid-mechanics 76e05-parallel-shear-flows},
  number = 7,
  pages = {721--735},
  posted-at = {2008-02-28 10:10:52},
  title = {{Finite Element Solution of the {Orr}--{Sommerfeld} Equation using High Precision {Hermite} Elements: Plane {Poiseuille} Flow}},
  url = {http://dx.doi.org/10.1002/fld.661},
  volume = 44,
