  journal = {Computer Methods in Applied Mechanics and Engineering},
  keywords = {65m06-pdes-ibvps-finite-differences 76e05-parallel-shear-flows 76e09-stability-and-instability-of-nonparallel-flows 76m20-finite-difference-methods-in-fluid-mechanics},
  pages = {287--304},
  privnote = {Cites Kirchner.},
