@article{davey1973simple,
  abstract = {In this paper we describe the simple method of complete orthonormalization which may be used to solve Orr–Sommerfeld problems, or other two-point boundary-value problems of a similar numerical character, whatever the differential order of the system and without any restriction on the size of parameters such as the Reynolds number or Prandtl number. To illustrate the effectiveness of the method we use it to calculate some stability characteristics of plane Poiseuille flow.},
